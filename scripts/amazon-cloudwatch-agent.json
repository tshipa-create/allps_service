{
	"agent": {
		"region": "us-east-1",
		"logfile": "/opt/aws/amazon-cloudwatch-agent/logs/amazon-cloudwatch-agent.log"
	},
	"logs": {
		"logs_collected": {
			"files": {
				"collect_list": [
					{
					"file_path": "/home/ec2-user/logs/allps_service.log*",
					"log_group_name": "/aws/ec2/allps_service/{instance_id}",
					"log_stream_name": "allps_service.log",
					"timezone": "UTC"
					}
			]
			}
		},
		"log_stream_name": "allps_service_stream",
		"force_flush_interval": 15
	}
}